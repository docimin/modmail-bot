{
 "type": "error",
 "info": "Sent to the Log Channel when a ticket is closed",
 "data": {
  "embeds": [
   {
    "author": {
     "name": "${usertag} (${userid}) | ${ticketid}",
     "url": "${host}/tickets/${ticketid}"
    },
    "description": "${reason}: ${commentpreview}",
    "footer": {
     "text": "Closed by ${authortag} (${authorid})",
     "icon_url": "${authoravatarurl}"
    },
    "timestamp": "${nowtimestamp}"
   }
  ]
 }
}